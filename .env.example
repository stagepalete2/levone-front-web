# ============================================
# Levone Frontend — Environment Variables
# ============================================
# Скопируйте этот файл: cp .env.example .env
# И заполните значения

# === BACKEND ===
VITE_BACKEND_DOMAIN=api.levoneapp.ru

# === TIMEZONE ===
VITE_TZ=Europe/Moscow

# === VK OAUTH ===
# ID вашего VK-приложения (https://dev.vk.com → Мои приложения)
VITE_VK_APP_ID=54473505

# ⚠️  КРИТИЧНО: Redirect URI для VK OAuth
# Должен ТОЧНО совпадать с полем "Доверенный redirect URI" в настройках VK-приложения!
# 
# Как настроить:
# 1. Зайдите на https://dev.vk.com/admin/app → выберите приложение
# 2. Вкладка "Настройки"  
# 3. Платформа: "Веб-сайт"
# 4. В поле "Адрес сайта" укажите домен (например: https://app.levoneapp.ru)
# 5. В поле "Базовый домен" укажите домен (например: app.levoneapp.ru)
# 6. В поле "Доверенный redirect URI" добавьте ТОЧНЫЙ URL:
#    - https://app.levoneapp.ru/             (если сайт на корне)  
#    - https://tunnel.levoneapp.ru/          (если через туннель)
#    - https://xxxx.ngrok-free.app/          (если через ngrok)
#    Можно добавить НЕСКОЛЬКО URI — по одному на строку
#
# ⚠️  Слеш в конце ВАЖЕН! 
#    "https://site.com/" и "https://site.com" — это РАЗНЫЕ URI для VK!
#    Проверьте что совпадает с тем, что показывает браузер
#
# Если не задано — используется автоматически window.location.origin + pathname
# Но лучше задать явно, чтобы не было сюрпризов:
VITE_VK_REDIRECT_URI=https://loyalupp.ru/
