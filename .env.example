# ============================================
# Levone Frontend — Environment Variables
# ============================================
# Скопируйте этот файл: cp .env.example .env
# И заполните значения

# === BACKEND ===
VITE_BACKEND_DOMAIN=api.levoneapp.ru

# === TIMEZONE ===
VITE_TZ=Europe/Moscow

# === VK ID OAUTH 2.1 ===
# ID вашего VK ID приложения (https://id.vk.ru/about/business/go)
VITE_VK_APP_ID=54473505

# Redirect URI для VK ID OAuth
# Должен ТОЧНО совпадать с настройками VK ID приложения!
# Слеш в конце ВАЖЕН!
VITE_VK_REDIRECT_URI=https://loyalupp.ru/
